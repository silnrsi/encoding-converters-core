FROM python:3.9
    
# Install steps mostly taken from https://medium.com/mlearning-ai/text-translation-using-nllb-and-huggingface-tutorial-7e789e0f7816

# Install main dependencies
RUN pip install transformers sentencepiece fasttext-wheel
# Install PyTorch. This command varies depending on your OS and other factors; see https://pytorch.org/get-started/locally/ for instructions for your system
RUN pip install torch torchvision torchaudio {0}
RUN pip install protobuf

# Copy settings first so import_model.py can validate paths
COPY settings.py .

# Validate model availability (this will check if model exists on host when container is run with proper volume mount)
# Note: The actual model validation happens at runtime in server.py since this container uses
# a volume-mounted model directory
RUN pip install flask
RUN pip install gevent

COPY . .

# The model is expected to be mounted at runtime via: docker run (--gpus "device=0") -v flag
# (add the optional /--gpus "device=0"/ if you have a GPU in your computer)
# Example (gpu): docker run --gpus "device=0" -v "C:\vscode\Models\Kangri\xnrHin_xnr_1:/app/model" -p 8000:8000 hin-xnr-translator
# Example (cpu-only): docker run -v "C:\vscode\Models\Kangri\xnrHin_xnr_1:/app/model" -p 8000:8000 hin-xnr-translator
# Or modify settings.py to point to /app/model inside the container
CMD ["python", "server.py"]
